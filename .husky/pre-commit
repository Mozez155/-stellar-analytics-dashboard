#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

pnpm exec lint-staged

# Skip tests if only lockfile or package.json changes are staged
STAGED_FILES=$(git diff --cached --name-only)
if echo "$STAGED_FILES" | grep -qE "^(pnpm-lock\.yaml|package\.json)$"; then
  # Only lockfile/package.json changes, skip tests
  exit 0
fi

# Run unit tests only, skip e2e tests to avoid timeout issues
pnpm --filter @stellar-analytics/api test -- --passWithNoTests
